PORT=5055
NODE_ENV=development
# NEVER set DEV_SKIP_OTP=true in production
DEV_SKIP_OTP=true
DEV_AUTO_DELIVER=false

# Smart Data Hub fulfillment API (https://smartdatahubgh.com)
FULFILLMENT_API_ENABLED=false
FULFILLMENT_API_URL=https://smartdatahubgh.com/api/v1
FULFILLMENT_API_KEY=
FULFILLMENT_API_SECRET=
FULFILLMENT_WEBHOOK_SECRET=

# Datamax fulfillment API (https://datamax.site)
DATAMAX_API_ENABLED=false
DATAMAX_API_URL=https://datamax.site/wp-json/api/v1
DATAMAX_API_KEY=

MONGODB_URI=mongodb://localhost:27017/data-bundle-reseller
# Use long random strings in production (required — server refuses weak defaults)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-distinct-from-jwt
ENCRYPTION_KEY=your-32-char-minimum-encryption-key-for-totp
JWT_EXPIRES_IN=2h

# Redis (optional in dev — required for multi-instance rate limiting in production)
REDIS_URL=

# Cloudflare (set true when origin is only reachable via Cloudflare proxy)
TRUST_CLOUDFLARE=false
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5055
# Comma-separated extra frontend origins for CORS (http + https if both used)
# CORS_ORIGINS=https://www.topdealsgh.com,http://www.topdealsgh.com,https://topdealsgh.com,https://resellers1.vercel.app
# Production (Vercel): FRONTEND_URL=https://www.topdealsgh.com  API_URL=https://backend-snowy-eight-68.vercel.app
# Paystack callbacks and reseller store links always use https://www.topdealsgh.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=topdealsgh <noreply@yourdomain.com>

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
PAYSTACK_WEBHOOK_SECRET=
# Comma-separated Paystack webhook IPs (defaults to official Paystack egress IPs)
PAYSTACK_WEBHOOK_IPS=

# Admin seed (first admin)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Platform Admin

# Demo accounts (auto-seeded for development)
DEMO_AGENT_EMAIL=agent@databundle.test
DEMO_AGENT_PASSWORD=Agent@12345
# Legacy aliases (still supported)
DEMO_DEALER_EMAIL=
DEMO_DEALER_PASSWORD=
DEMO_RESELLER_EMAIL=reseller@databundle.test
DEMO_RESELLER_PASSWORD=Reseller@12345

# SMS (optional — checker delivery)
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=

UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
